        "import pandas as pd\n",
        "#Assign data\n",
        "data={'Name':['Sai','Yuvasri','Poovannan',\n",
        "'Sabharish','Sangamithra','Rithika','Rubasri'],\n",
        "'Age':[20,18,19,20,18,17,19],\n",
        "'Gender':['M','F','M','M','F','F','F'],\n",
        "'Marks':[90,76,'NaN',74,65,'NaN',71]}\n",
        "#convert into datafram\n",
        "df=pd.DataFrame(data)\n",
        "#display data\n",
        "print(\"Original DataFrame:\\n\",df)\n",
        "\n",
        "# Calculate average of numeric marks\n",
        "c = 0\n",
        "total_marks = 0\n",
        "for ele in df['Marks']:\n",
        "    if str(ele).isnumeric(): # This checks if the string representation is numeric\n",
        "        c += 1\n",
        "        total_marks += int(ele) # Convert to int before adding\n",
        "\n",
        "# Calculate average after iterating through all elements\n",
        "if c > 0:\n",
        "    avg = total_marks / c\n",
        "else:\n",
        "    avg = 0 # Handle case where no numeric marks are found\n",
        "\n",
        "#Replace missing values (string \"NaN\") with the calculated average\n",
        "df=df.replace(to_replace=\"NaN\",value=avg)\n",
        "#Display data\n",
        "print(\"\\nReplacing NaN with average marks:\\n\",df)"
